{
  "name": "odysseus-vscode-extension",
  "displayName": "Odysseus AI Helper",
  "description": "Ask questions to your local Odysseus AI server (http://localhost:7000)",
  "version": "0.0.1",
  "publisher": "JoseAlma",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [],
  "main": "./out/extension",
  "contributes": {
    "commands": [
      {
        "command": "odysseus.openChat",
        "title": "Open Chat",
        "category": "Odysseus"
      },
      {
        "command": "odysseus.configure",
        "title": "Configure",
        "category": "Odysseus"
      },
      {
        "command": "odysseus.newSession",
        "title": "New Session",
        "category": "Odysseus"
      },
      {
        "command": "odysseus.sendSelection",
        "title": "Send Selection to Chat",
        "category": "Odysseus"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "odysseus",
          "title": "Odysseus",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "odysseus": [
        {
          "type": "webview",
          "id": "odysseus.chatView",
          "name": "Odysseus AI"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.0.0"
  }
}
