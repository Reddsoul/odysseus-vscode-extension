{
  "name": "odysseus",
  "displayName": "Odysseus vscode Extension",
  "description": "Chat panel for Odysseus — a self-hosted AI assistant with agent tools, streaming, and session management.",
  "version": "0.0.20",
  "publisher": "JoseAlma",
  "license": "MIT",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Reddsoul/odysseus-vscode-extension.git"
  },
  "bugs": {
    "url": "https://github.com/Reddsoul/odysseus-vscode-extension/issues"
  },
  "homepage": "https://github.com/Reddsoul/odysseus-vscode-extension#readme",
  "galleryBanner": {
    "color": "#191929",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [],
  "main": "./out/extension",
  "contributes": {
    "commands": [
      {
        "command": "odysseus.openChat",
        "title": "Open Chat",
        "category": "Odysseus"
      },
      {
        "command": "odysseus.configure",
        "title": "Configure",
        "category": "Odysseus"
      },
      {
        "command": "odysseus.newSession",
        "title": "New Session",
        "category": "Odysseus"
      },
      {
        "command": "odysseus.sendSelection",
        "title": "Send Selection to Odysseus",
        "category": "Odysseus"
      },
      {
        "command": "odysseus.insertAtMention",
        "title": "Insert @-mention for Current File/Selection",
        "category": "Odysseus"
      },
      {
        "command": "odysseus.openNewChat",
        "title": "Open New Chat Panel",
        "category": "Odysseus"
      },
      {
        "command": "odysseus.searchMessages",
        "title": "Search Messages",
        "category": "Odysseus"
      },
      {
        "command": "odysseus.createRulesFile",
        "title": "Create .odysseusrules",
        "category": "Odysseus"
      },
      {
        "command": "odysseus.cancelRun",
        "title": "Cancel Active Run",
        "category": "Odysseus"
      },
      {
        "command": "odysseus.rebuildWorkspaceIndex",
        "title": "Rebuild Workspace Index",
        "category": "Odysseus"
      },
      {
        "command": "odysseus.searchCodebase",
        "title": "Search Codebase",
        "category": "Odysseus"
      },
      {
        "command": "odysseus.revertSession",
        "title": "Revert Agent Run",
        "category": "Odysseus"
      },
      {
        "command": "odysseus.runTask",
        "title": "Run Headless Task",
        "category": "Odysseus"
      },
      {
        "command": "odysseus.showTaskHistory",
        "title": "Show Task History",
        "category": "Odysseus"
      },
      {
        "command": "odysseus.scheduleTask",
        "title": "Schedule New Task",
        "category": "Odysseus"
      },
      {
        "command": "odysseus.showSchedules",
        "title": "Manage Schedules",
        "category": "Odysseus"
      },
      {
        "command": "odysseus.showSessionDiff",
        "title": "Show Session Diff",
        "category": "Odysseus"
      },
      {
        "command": "odysseus.generateCommitMessage",
        "title": "Generate Commit Message",
        "category": "Odysseus"
      }
    ],
    "keybindings": [
      {
        "command": "odysseus.insertAtMention",
        "key": "alt+k",
        "mac": "alt+k",
        "when": "editorFocus"
      },
      {
        "command": "odysseus.openChat",
        "key": "ctrl+shift+o",
        "mac": "cmd+shift+o"
      },
      {
        "command": "odysseus.searchMessages",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f",
        "when": "false"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "odysseus.sendSelection",
          "when": "editorHasSelection",
          "group": "navigation@99"
        },
        {
          "command": "odysseus.insertAtMention",
          "when": "editorHasSelection",
          "group": "navigation@100"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "odysseus",
          "title": "Odysseus",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "configuration": {
      "title": "Odysseus",
      "properties": {
        "odysseus.url": {
          "type": "string",
          "default": "http://localhost:7860",
          "description": "Odysseus server URL"
        },
        "odysseus.useCtrlEnterToSend": {
          "type": "boolean",
          "default": false,
          "description": "When enabled, use Ctrl+Enter (or Cmd+Enter on Mac) to send messages. Plain Enter adds a newline."
        },
        "odysseus.agentMode": {
          "type": "boolean",
          "default": true,
          "description": "Enable agent mode by default (allows bash tool execution)"
        },
        "odysseus.allowBash": {
          "type": "boolean",
          "default": true,
          "description": "Allow the agent to run bash commands"
        },
        "odysseus.allowWebSearch": {
          "type": "boolean",
          "default": true,
          "description": "Allow the agent to perform web searches"
        },
        "odysseus.maxIterations": {
          "type": "number",
          "default": 30,
          "description": "Maximum agentic loop iterations before pausing"
        },
        "odysseus.requireApproval": {
          "type": "boolean",
          "default": true,
          "description": "Require approval before bash commands and file writes"
        },
        "odysseus.promptToCommit": {
          "type": "boolean",
          "default": false,
          "description": "Offer to generate a commit message after agent file changes"
        },
        "odysseus.injectGitContext": {
          "type": "boolean",
          "default": true,
          "description": "Inject git status and diff into agentic task context"
        },
        "odysseus.injectWorkspaceTree": {
          "type": "boolean",
          "default": true,
          "description": "Inject workspace file listing into agentic task context"
        },
        "odysseus.schedulerTimeoutMinutes": {
          "type": "number",
          "default": 30,
          "description": "Maximum minutes a scheduled task may run before being stopped"
        }
      }
    },
    "views": {
      "odysseus": [
        {
          "type": "webview",
          "id": "odysseus.chatView",
          "name": "Odysseus AI",
          "icon": "resources/icon.svg"
        },
        {
          "type": "webview",
          "id": "odysseus.schedulerView",
          "name": "Schedules",
          "icon": "resources/icon.svg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node node_modules/typescript/bin/tsc -p ./",
    "watch": "node node_modules/typescript/bin/tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/vscode": "^1.85.0",
    "marked": "^18.0.5",
    "typescript": "^5.0.0"
  }
}
