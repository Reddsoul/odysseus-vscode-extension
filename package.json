{
  "name": "odysseus-vscode-extension",
  "displayName": "Odysseus AI Helper",
  "description": "Ask questions to your local Odysseus AI server (http://localhost:7860)",
  "version": "0.0.1",
  "publisher": "JoseAlma",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [],
  "main": "./out/extension",
  "contributes": {
    "commands": [
      {
        "command": "odysseus.openChat",
        "title": "Open Chat",
        "category": "Odysseus"
      },
      {
        "command": "odysseus.configure",
        "title": "Configure",
        "category": "Odysseus"
      },
      {
        "command": "odysseus.newSession",
        "title": "New Session",
        "category": "Odysseus"
      },
      {
        "command": "odysseus.sendSelection",
        "title": "Send Selection to Odysseus",
        "category": "Odysseus"
      },
      {
        "command": "odysseus.insertAtMention",
        "title": "Insert @-mention for Current File/Selection",
        "category": "Odysseus"
      },
      {
        "command": "odysseus.openNewChat",
        "title": "Open New Chat Panel",
        "category": "Odysseus"
      },
      {
        "command": "odysseus.searchMessages",
        "title": "Search Messages",
        "category": "Odysseus"
      }
    ],
    "keybindings": [
      {
        "command": "odysseus.insertAtMention",
        "key": "alt+k",
        "mac": "alt+k",
        "when": "editorFocus"
      },
      {
        "command": "odysseus.openChat",
        "key": "ctrl+shift+o",
        "mac": "cmd+shift+o"
      },
      {
        "command": "odysseus.searchMessages",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f",
        "when": "false"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "odysseus.sendSelection",
          "when": "editorHasSelection",
          "group": "navigation@99"
        },
        {
          "command": "odysseus.insertAtMention",
          "when": "editorHasSelection",
          "group": "navigation@100"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "odysseus",
          "title": "Odysseus",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "configuration": {
      "title": "Odysseus",
      "properties": {
        "odysseus.url": {
          "type": "string",
          "default": "http://localhost:7860",
          "description": "Odysseus server URL"
        },
        "odysseus.useCtrlEnterToSend": {
          "type": "boolean",
          "default": false,
          "description": "When enabled, use Ctrl+Enter (or Cmd+Enter on Mac) to send messages. Plain Enter adds a newline."
        },
        "odysseus.agentMode": {
          "type": "boolean",
          "default": true,
          "description": "Enable agent mode by default (allows bash tool execution)"
        },
        "odysseus.allowBash": {
          "type": "boolean",
          "default": true,
          "description": "Allow the agent to run bash commands"
        },
        "odysseus.allowWebSearch": {
          "type": "boolean",
          "default": true,
          "description": "Allow the agent to perform web searches"
        }
      }
    },
    "views": {
      "odysseus": [
        {
          "type": "webview",
          "id": "odysseus.chatView",
          "name": "Odysseus AI"
        },
        {
          "type": "webview",
          "id": "odysseus.memoryView",
          "name": "Memories"
        },
        {
          "type": "webview",
          "id": "odysseus.notesView",
          "name": "Notes"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/vscode": "^1.85.0",
    "marked": "^18.0.5",
    "typescript": "^5.0.0"
  }
}
